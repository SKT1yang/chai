{
	"name": "@chai/vscode",
	"displayName": "Chai",
	"version": "0.0.1",
	"private": true,
	"description": "Autonomous coding agent right in your IDE, capable of creating/editing files, running commands, using the browser, and more with your permission every step of the way.",
	"categories": [
		"AI",
		"Chat",
		"Machine Learning",
		"Programming Languages"
	],
	"keywords": [
		"ai",
		"autocomplete",
		"c#",
		"c++",
		"chai",
		"chat",
		"codex",
		"documentation",
		"go",
		"golang",
		"intellisense",
		"java",
		"javascript",
		"kotlin",
		"openai",
		"php",
		"python",
		"refactor",
		"ruby",
		"snippets",
		"typescript"
	],
	"bugs": {
		"url": "https://github.com/SKT1yang/chai/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SKT1yang/chai.git"
	},
	"publisher": "shuiyangsuan",
	"main": "./dist/main.js",
	"scripts": {
		"compile": "rolldown -c rolldown.config.ts",
		"watch:compile": "pnpm compile --watch",
		"package": "vsce package --no-dependencies -o chai.vsix",
		"package:pre-release": "vsce package --no-dependencies --pre-release -o chai.vsix",
		"install-extension": "code --install-extension chai.vsix --force"
	},
	"dependencies": {
		"axios": "^1.15.0",
		"vscode-uri": "3.1.0"
	},
	"devDependencies": {
		"@chai/webview": "workspace:",
		"@types/node": "catalog:",
		"@types/vscode": "1.109.0",
		"@vscode/vsce": "3.7.1",
		"cross-env": "10.1.0",
		"ovsx": "0.10.9",
		"rolldown": "1.0.0-rc.6",
		"tinyglobby": "0.2.15"
	},
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "chai",
					"title": "Chai",
					"icon": "assets/chai.svg"
				}
			]
		},
		"views": {
			"chai": [
				{
					"id": "chai",
					"type": "webview",
					"name": "Chai",
					"icon": "assets/chai.svg"
				}
			]
		},
		"commands": []
	},
	"activationEvents": [],
	"icon": "assets/chai.png",
	"engines": {
		"vscode": "^1.109.0"
	},
	"vsce": {
		"dependencies": false
	}
}
