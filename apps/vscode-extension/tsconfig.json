{
	"extends": "@shuiyangsuan/tsconfig/node",
	"compilerOptions": {
		"lib": ["ESNext.Disposable", "DOM"],
		"types": ["node"],

		"exactOptionalPropertyTypes": false,
		"useUnknownInCatchVariables": false,

		"experimentalDecorators": true,
		"useDefineForClassFields": true,
		"sourceMap": true
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
