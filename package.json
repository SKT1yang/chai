{
	"name": "chai-workspace",
	"private": true,
	"type": "module",
	"scripts": {
		"build:vscode": "bun scripts/build-vscode.ts",
		"clean": "by delete",
		"check": "pnpm lint && pnpm fmt",
		"lint": "oxlint --type-check --type-aware -c oxlint.config.ts",
		"fmt": "oxfmt --write -c oxfmt.config.ts"
	},
	"devDependencies": {
		"@shuiyangsuan/cli": "0.0.6",
		"@tsconfig/strictest": "catalog:",
		"@types/bun": "1.3.10",
		"@types/node": "catalog:",
		"bun": "1.3.10",
		"oxfmt": "0.41.0",
		"oxlint": "1.56.0",
		"oxlint-tsgolint": "0.17.0",
		"turbo": "2.8.17",
		"typescript": "catalog:"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"packageManager": "pnpm@10.28.0"
}
