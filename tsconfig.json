{
	"extends": "@tsconfig/strictest/tsconfig.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"lib": ["ES2022"],
		"tsBuildInfoFile": ".tsbuildinfo",

		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"resolveJsonModule": true,

		"composite": true,
		"incremental": true,
	},
	"include": ["scripts/**/*.ts", "*.config.ts"],
	"exclude": ["node_modules", "dist", ".turbo"],
}
